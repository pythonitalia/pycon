{
  "compilerOptions": {
    "target": "es5",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"],
      "@python-italia/pycon-styleguide/icons": [
        "./node_modules/@python-italia/pycon-styleguide/dist/icons"
      ],
      "@python-italia/pycon-styleguide/illustrations": [
        "./node_modules/@python-italia/pycon-styleguide/dist/illustrations"
      ],
      "@python-italia/pycon-styleguide/config-parts": [
        "./node_modules/@python-italia/pycon-styleguide/dist/config-parts"
      ],
      "@python-italia/pycon-styleguide/dist/types": [
        "./node_modules/@python-italia/pycon-styleguide/dist/types"
      ],
      "@python-italia/pycon-styleguide/dist/icons/types": [
        "./node_modules/@python-italia/pycon-styleguide/dist/icons/types"
      ],
      "@python-italia/pycon-styleguide/dist/illustrations/types": [
        "./node_modules/@python-italia/pycon-styleguide/dist/illustrations/types"
      ],
      "@python-italia/pycon-styleguide/dist/navbar/types": [
        "./node_modules/@python-italia/pycon-styleguide/dist/navbar/types"
      ]
    },
    "incremental": true
  },
  "exclude": ["node_modules"],
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "src/helpers/lodash-is-equal.ts"
  ]
}
